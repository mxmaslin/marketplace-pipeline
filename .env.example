# Demo / local run — copy to .env (never commit .env; use your own secrets below)
DEMO_MODE=true
DEMO_PRODUCT_COUNT=100
TARGET_PRODUCT_COUNT=10000

# Mock modes (recommended for local dev and CI)
MOCK_PARSER=true
MOCK_LLM=true
MOCK_CRM=true

# Ozon (used when MOCK_PARSER=false)
OZON_CATEGORY_PATH=/category/smartfony-15502/
OZON_API_BASE_URL=https://www.ozon.ru/api/composer-api.bx/page/json/v2
OZON_PAGE_SIZE=36
# Anti-bot (live Ozon): bring your own residential/mobile proxy list — never commit real credentials
# OZON_PROXY_LIST=http://user:pass@host1:8080,http://user:pass@host2:8080
# OZON_COOKIE=copy from browser DevTools after visiting ozon.ru (merged with Set-Cookie)
OZON_REQUEST_DELAY_SECONDS=1.0
# Optional random jitter between page fetches (overrides fixed delay when both set):
# OZON_REQUEST_DELAY_MIN_SECONDS=0.8
# OZON_REQUEST_DELAY_MAX_SECONDS=2.5
OZON_FOLLOW_REDIRECTS=true
OZON_WARMUP_SESSION=true
OZON_ROTATE_USER_AGENTS=true

# proxy.market (optional pre-flight when MOCK_PARSER=false + OZON_PROXY_LIST set)
# API key from dashboard → API; docs: https://api.dashboard.proxy.market/docs
# PROXY_MARKET_API_KEY=
# PROXY_MARKET_MIN_TRAFFIC_BYTES=1048576

# OpenAI (used when MOCK_LLM=false)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_BATCH_SIZE=25

# AmoCRM (used when MOCK_CRM=false)
AMOCRM_SUBDOMAIN=
AMOCRM_ACCESS_TOKEN=
AMOCRM_RESPONSIBLE_USER_ID=0
CRM_IDEMPOTENCY_ENABLED=true
CRM_IDEMPOTENCY_STORE_PATH=data/crm_idempotency.json

# HTTP retries
HTTP_MAX_RETRIES=5
HTTP_RETRY_BASE_DELAY=1.0
LOG_LEVEL=INFO

# API (FastAPI job service)
JOB_DB_PATH=data/jobs.sqlite
API_JOB_WORKERS=2
# API_KEY=change-me-in-production
API_RATE_LIMIT_PER_MINUTE=60
JOB_IDEMPOTENCY_TTL_SECONDS=86400
LOG_JSON=false

# Scale profile (Postgres + Celery + Redis): see .env.scale.example
