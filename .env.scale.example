# Multi-node profile — use with: docker compose --profile scale up --build

DEMO_MODE=true
MOCK_PARSER=true
MOCK_LLM=true
MOCK_CRM=true
DEMO_PRODUCT_COUNT=100

JOB_STORE_BACKEND=postgres
DATABASE_URL=postgresql://pipeline:pipeline@postgres:5432/pipeline

JOB_RUNNER_BACKEND=celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

CRM_IDEMPOTENCY_BACKEND=redis
CRM_IDEMPOTENCY_ENABLED=true
JOB_IDEMPOTENCY_TTL_SECONDS=86400

API_JOB_WORKERS=2
LOG_JSON=true

# Optional observability
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
# SENTRY_DSN=
